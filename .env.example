# Anthropic API key for the v0.2 in-character chat (frontend-only prototype).
# Copy this file to .env and fill in your key. .env is gitignored.
#
# NOTE: v0.2 is the ONLY phase where the key lives in the browser. From v2.5
# chat moves to the REST backend (POST /chat) and the key never reaches the frontend.
VITE_ANTHROPIC_API_KEY=

# ── Backend (v1+) ───────────────────────────────────────────────────────────
# Anthropic API key for the backend — server-side only, never shipped to the
# browser. Unused in v1.1; wired into chat at v1.4.
ANTHROPIC_API_KEY=
# World tick interval in milliseconds (backend).
HAVEN_TICK_MS=1000
