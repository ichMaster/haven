# Anthropic API key for the v0.2 in-character chat (frontend-only prototype).
# Copy this file to .env and fill in your key. .env is gitignored.
#
# NOTE: v0.2 is the ONLY phase where the key lives in the browser. From v1.5
# chat moves to the backend (POST /chat) and the key never reaches the frontend.
VITE_ANTHROPIC_API_KEY=
